@using WebApplication3
@model ToDoViewModel

<div class="row justify-content-center">
    <div class="col-12 col-xl-10">
        <div class="card border-secondary shadow-lg bg-dark bg-gradient">

            <div class="card-header bg-transparent border-secondary p-4">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div>
                        <h1 class="h3 text-light fw-semibold mb-1">Add Task</h1>
                        <p class="text-secondary mb-0">Everything here maps directly to the existing save action.</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4 p-md-5">
                <form method="POST" action="/home/AddToDo">
                    <div>
                        <label class="form-label fw-semibold text-light">Task</label>
                        <input type="text" class="form-control form-control-lg border-secondary rounded-3 bg-dark text-light" name="Title" />
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold text-light">Due Date</label>
                        <input type="date" class="form-control form-control-lg border-secondary rounded-3 bg-dark text-light" name="DueDate" />
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold text-light">Category</label>
                        <select class="form-select form-select-lg border-secondary rounded-3 bg-dark text-light" name="CatId">
                            @foreach (Category cat in Model.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="d-grid mt-4">
                        <button class="btn btn-info text-dark btn-lg rounded-pill fw-semibold shadow-sm">Save Task</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>