@using WebApplication3.Models
@model ToDoViewModel

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">
            <div class="card border-secondary shadow-lg bg-dark bg-gradient">
                <div class="card-header bg-transparent border-secondary p-4">
                    <h1 class="h3 text-light fw-semibold mb-1">Edit Category</h1>
                    <p class="text-secondary mb-0">Rename category without changing any linked tasks.</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post" action="/Home/EditCategory">
                        <label class="form-label fw-semibold text-light">Category Name</label>
                        <input type="text" class="form-control form-control-lg border-secondary rounded-3 bg-dark text-light" value="@Model.Category.Name" name="category.Name" />
                        <input type="hidden" name="category.Id" value="@Model.Category.Id" />
                        <div class="d-grid mt-4">
                            <button class="btn btn-info text-dark btn-lg rounded-pill fw-semibold shadow-sm">Update Category</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
