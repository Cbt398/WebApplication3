@using WebApplication3.Models
@model ToDoViewModel

<div class="row justify-content-center">
    <div class="col-12 col-xl-10">
        <div class="card border-secondary shadow-lg bg-dark bg-gradient">

            <div class="card-header bg-transparent border-secondary p-4">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div>
                        <h1 class="h3 text-light fw-semibold mb-1">Active Tasks</h1>
                        <p class="text-secondary mb-0">A cleaner queue view with fast actions.</p>
                    </div>
                    <a href="/home/addToDo" class="btn btn-info text-dark fw-semibold px-4">Create Task</a>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @foreach (ToDoItems toDo in Model.ToDo)
                    {
                        <div class="list-group-item bg-transparent border-secondary px-4 py-3">
                            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">

                                <div>
                                    @if (toDo.DueDate < DateTime.Now)
                                    {
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                            <span class="text-light fw-semibold fs-5">@toDo.Title</span>
                                            <span class="badge bg-secondary">@toDo.Category</span>
                                            <span class="badge bg-danger text-white">Overdue</span>
                                        </div>
                                        <div class="small text-warning">Due: @toDo.DueDate.ToString()</div>
                                    }
                                    else if (toDo.DueDate > DateTime.Now)
                                    {
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                            <span class="text-light fw-semibold fs-5">@toDo.Title</span>
                                            <span class="badge bg-secondary">@toDo.Category</span>
                                        </div>
                                        <div class="small text-secondary">Due: @toDo.DueDate.ToString()</div>
                                    }
                                </div>

                                <form method="post" action="/home/markcompleted" class="m-0">
                                    <input name="id" value="@toDo.Id" type="hidden" />
                                    <button class="btn btn-outline-info fw-semibold">Mark Completed</button>
                                </form>

                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>